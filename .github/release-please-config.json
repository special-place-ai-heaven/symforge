{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "rust",
      "package-name": "symforge",
      "include-v-in-tag": true,
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "npm/package.json",
        {
          "type": "json",
          "path": "npm/package.json",
          "jsonpath": "$.optionalDependencies['symforge-linux-x64']"
        },
        {
          "type": "json",
          "path": "npm/package.json",
          "jsonpath": "$.optionalDependencies['symforge-macos-arm64']"
        },
        {
          "type": "json",
          "path": "npm/package.json",
          "jsonpath": "$.optionalDependencies['symforge-macos-x64']"
        },
        {
          "type": "json",
          "path": "npm/package.json",
          "jsonpath": "$.optionalDependencies['symforge-windows-x64']"
        },
        "npm/platforms/linux-x64/package.json",
        "npm/platforms/macos-arm64/package.json",
        "npm/platforms/macos-x64/package.json",
        "npm/platforms/windows-x64/package.json"
      ]
    }
  }
}
