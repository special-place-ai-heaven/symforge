/target
# Custom CARGO_TARGET_DIR variants (e.g. target-wsl on dual Windows/WSL setups).
/target-*/

# Root-level tool and harness state directories.
/.*/
!/.cargo/
/.cargo/*
!/.cargo/config.toml
!/.github/

# Nested SymForge local cache (e.g. npm/.symforge/) — local state, never tracked.
**/.symforge/

# Grok CLI per-project MCP working dir (created during dogfooding) — not repo content.
/mcps/

npm/*.tgz
.env
spacetime/*/target/
__pycache__/

# Windows NUL device name — some tools accidentally create a tracked 'nul' file
nul

.octogent
