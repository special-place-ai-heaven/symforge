pub const fn as_str(self) -> &'static str {
        match self {
            Self::Orient => "orient",
            Self::Find => "find",
            Self::Read => "read",
            Self::Trace => "trace",
            Self::Impact => "impact",
            Self::Edit => "edit",
            Self::Meta => "meta",
            Self::Auto => "auto",
        }
    }
